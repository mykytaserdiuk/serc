use math
use http

func index(body):
     printf("body: %s", body)
     return "TEST"
end

func main():
     printf("%+v\n", math.add(1, 5))

     def out = http.get("/", index)
     printf("out: %s \n", out)
     
     def err = http.serve(":8080")
     printf("err: %v \n", err)
     for (1==1) 
          print("tick \n")
     end
end
