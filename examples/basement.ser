func foo():
     print("foo(): 1\n")
     return

     print("foo(): may dont print\n")
end

func retNull():
     return
end

func returnData():
     foo()
     return "test String"
end

func main():
     def data = "1abc"
     ; return
     print("main():", data, "\n")

     data = retNull()
     printf("main(): %s\n", data)

     if (5+2 <> 6) then
        data = returnData()
     end

     printf("main(): %s\n", data)
end
