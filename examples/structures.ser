struct User (
    first_name
    lastName
)

func main():
    def data = User(
        first_name: "Oleg"
        lastName: "Vinnic"
    )
    data.first_name = "Daniel"
    data.lastName = send(data)

    printf("%+v\n", data)
end

func send(user):
    printf("%+v\n", user)
    return "Muller"
end
